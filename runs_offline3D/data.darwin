 grp_nplank(:)=          1, 1,
 grp_photo(:)=           1, 0,
 grp_pred(:)=            0, 1,
 grp_prey(:)=            1, 0,
 grp_hasSi(:)=           0, 0,
 grp_hasPIC(:)=          0, 0,
 grp_DIAZO(:)=           0, 0,
 grp_useNH4(:)=          1, 0,
 grp_useNO2(:)=          1, 0,
 grp_useNO3(:)=          1, 0,
 grp_combNO(:)=          1, 0,
