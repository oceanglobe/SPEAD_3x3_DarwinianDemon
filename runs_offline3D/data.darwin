#a_grazemax(3:4) = 3.0, 0.6 ! Grazing rate at 20C
#a_grazemax(3:4) = 4.0, 0.5
#a_grazemax(3:4) = 2.0, 0.25
#a_grazemax(3:4) = 1.5, 0.15
#a_grazemax(3:4) = 1.0, 0.15
#a_grazemax(3:4) = 1.0, 0.2
#a_grazemax(3:4) = 1.2, 0.4
#a_grazemax(3:4) = 1.5, 0.45
#a_grazemax(3:4) = 1.2, 0.36
#a_grazemax(3:4) = 1.0, 0.4
#a_grazemax(3:4) = 0.9, 0.3
#a_grazemax(3:4) = 1.33, 0.4
#a_grazemax(2) = 1.4,
#a_grazemax(2) = 2.0,
#a_grazemax(2) = 1.5,
#a_grazemax(2) = 1.2,
 a_grazemax(2) = 1.0,     ! Default value for Le Gland et al.
#a_grazemax(2) = 0.5,
 a_grazemax_denom(2) = 86400, ! d-1 -> s-1
 b_grazemax(2) = 0., ! Standard is -0.16
#a_kgrazesat(3:4) = 2*3.0, ! Grazing half-sat, in mmolC/m3 (Standard is 1.0)
#a_kgrazesat(3:4) = 2*1.8, ! Based on the optimized value of Chen et al. [2018] 
#a_kgrazesat(3:4) = 2*1.0,
#a_kgrazesat(3:4) = 1.0, 1.5,
#a_kgrazesat(3:4) = 1.0, 2.0,
#a_kgrazesat(3:4) = 1.0, 3.0,
#a_kgrazesat(3:4) = 1.5, 1.5,
#a_kgrazesat(3:4) = 2.0, 2.0,
#a_kgrazesat(3:4) = 2.0, 3.0,
#a_kgrazesat(2) = 3.0,
 a_kgrazesat(2) = 2.0,   ! Value from Le Gland et al.
#a_kgrazesat(2) = 1.5,
# allometric palatabilities for each pair of groups (Le Gland, 10/06/2021)
 a_palat(1:2,1) = 2*0.
 b_palat(1:2,1) = 2*0.
#a_palat(1:2,2) = 1., 0.,
 a_palat(1:2,2) = 0.9, 0.,   ! Value from Guillaume
#a_palat(1:2,2) = 0.8, 0.,
#b_palat(1:2,2) = 2*0.,
 b_palat(1:2,2) = -0.05, 0., ! From Bingzhang Chen (CITRATE, 2018); Value From Guillaume
#b_palat(1:2,2) = -0.1, 0.,
