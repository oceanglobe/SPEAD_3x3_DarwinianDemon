 a_mort(:) = 5.787e-07, 1.157e-07, ! .05/day, .01/day ! Guillaume's default value 
#a_mort(:) = 1.157e-06, 1.157e-07, ! .05/day, .01/day ! Faster phyto's death to prevent overly small sizes (Boris Sauterey 07/10/23) 
#a_mort(:) = 5.787e-07, 8.681e-08, ! .05/day, .0075/day
#a_mort(:) = 4.630e-07, 5.787e-08, ! .04/day, .005/day
#a_mort(:) = 4.630e-07, 1.157e-07, ! .04/day, .01/day
#a_mort2(:) = 0., 2.315e-06, ! Zooplankton carrying capacity of 7 mmolC/m3
#a_mort2(:) = 0., 1.852e-06, ! Zooplankton carrying capacity of 8.75 mmolC/m3
#a_mort2(:) = 0., 1.621e-06, ! Zooplankton carrying capacity of 7.5 mmolC/m3
#a_mort2(:) = 0., 1.215e-06, ! Zooplankton carrying capacity of 8 mmolC/m3
 a_mort2(:) = 0., 1.157e-06, ! Zooplankton carrying capacity of 7 mmolC/m3
 a_ExportFracMort(:) = 2*0.5, ! Standard value of DARWIN
 a_ExportFracMort2(:) = 2*0.5,
 a_phytoTempExp1(:) = 2*0.056, ! Phytoplankton temperature dependency
#Trait diffusion parameters (Le Gland, 18/12/2020)
