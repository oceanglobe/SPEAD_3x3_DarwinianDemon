#grp_ExportFracPreyPred(1:2,3:4)= 4*0.667,
#grp_ExportFracPreyPred(1:2,3:4)= 4*0.5, ! Standard value in DARWIN3
 grp_ExportFracPreyPred(1,2)= 0.5,
# max photosynthesis rates
#a_PCmax(:)= 2*1.2,
#a_PCmax(:)= 2*1.33,
#a_PCmax(:)= 2*1.5,
#a_PCmax(:)= 2*1.8,
#a_PCmax(:)= 0.45,
#a_PCmax(:)= 0.5,  ! Default value
 a_PCmax(:)= 1.0,  ! Value from Le Gland et al. ?
#a_PCmax(:)= 2.0,  
 a_PCmax_denom(:)= 86400.,
#b_PCmax(:)= 0.135,  ! Guillaume's default value
 b_PCmax(:)= 0.17,    ! Higher value value to select larger sizes and increase PC (Boris Sauterey 07/10/23)
#b1_PCmax(:)= 2*0.25,
#b2_PCmax(:)= 2*-0.25,
#c_PCmax(:)= 2*148.4, ! Volume for optimal PCmax
# zoo have approx Redfield N:C
 a_Qnmax(2)=0.1510,
 b_Qnmax(2)=0.0,
 a_Qnmin(2)=0.0755,
 b_Qnmin(2)=0.0,
#Turn off silica
