#a_ksatNO2(1) = 0.08,
#a_ksatNH4(1) = 0.04,
#a_ksatPO4(1) = 0.013,
#a_ksatFeT(1) = 4.0e-05,
 b_ksatNO3(1) = 0.27,
 b_ksatNO2(1) = 0.27,
 b_ksatNH4(1) = 0.27,
 b_ksatPO4(1) = 0.27,
 b_ksatFeT(1) = 0.27,
